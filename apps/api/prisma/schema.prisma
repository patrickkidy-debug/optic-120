// OculoSaaS — Schéma Prisma (Phase 1)
// Multi-tenant par colonne tenantId + isolation forcée via Prisma Client Extension.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ---------------- TENANCY ---------------- */

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

model Tenant {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  logoUrl       String?
  // Situation géographique de l'établissement (adresse ou lien de carte).
  location      String?
  // Personnalisation des documents (factures/devis) : couleur d'accent, mentions
  // légales, note de bas de page, validité des devis. null = valeurs par défaut.
  invoiceSettings Json?
  // Numéro WhatsApp du responsable de l'établissement, collecté à l'inscription
  // (obligatoire côté formulaire) pour permettre au fondateur de le contacter.
  whatsappPhone String?
  status        TenantStatus @default(ACTIVE)
  currency      String       @default("XOF")
  // Config CinetPay (apiKey chiffrée au repos). null = mode simulation par défaut.
  paymentConfig Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  branches      Branch[]
  users         User[]
  roles         Role[]
  products      Product[]
  stockItems    StockItem[]
  stockMovements StockMovement[]
  customers     Customer[]
  prescriptions OpticalPrescription[]
  sales         Sale[]
  payments      Payment[]
  cashRegisters CashRegister[]
  auditLogs     AuditLog[]
  patients      Patient[]
  consultations Consultation[]
  appointments  Appointment[]
  surgeries     Surgery[]
  employees     Employee[]
  expenses      Expense[]
  suppliers     Supplier[]
  insurers      Insurer[]
  lensOrders    LensOrder[]
  repairs       Repair[]
  subscription  Subscription?
  subInvoices   SubscriptionInvoice[]
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  city      String?
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  stockItems    StockItem[]
  sales         Sale[]
  cashRegisters CashRegister[]
  users         UserBranch[]

  @@index([tenantId])
}

/* ---------------- IDENTITY & RBAC ---------------- */

model User {
  id               String    @id @default(uuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email            String
  username         String?
  passwordHash     String
  firstName        String
  lastName         String
  phone            String?
  photoUrl         String?
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  resetTokenHash      String?
  resetTokenExpiresAt DateTime?
  emailVerifiedAt      DateTime?
  verifyTokenHash      String?
  verifyTokenExpiresAt DateTime?
  googleId         String?   @unique // identifiant Google (sub) si connecté via "Se connecter avec Google"
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String? // secret TOTP chiffré (AES-256-GCM)
  preferences      Json? // { theme: 'light'|'dark'|'auto', locale: 'fr'|'en'|'pt', ... }
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  roleId        String
  role          Role           @relation(fields: [roleId], references: [id])
  branches      UserBranch[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  sales         Sale[]

  @@unique([tenantId, email])
  @@unique([tenantId, username])
  @@index([tenantId])
}

model UserBranch {
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([branchId])
}

model Role {
  id        String   @id @default(uuid())
  tenantId  String? // null = rôle système/template global
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String // identifiant stable (ex: "admin", "caissier")
  name      String // libellé affiché
  isSystem  Boolean  @default(false)
  isCustom  Boolean  @default(false)
  allBranches Boolean @default(false)
  createdAt DateTime @default(now())

  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model Permission {
  id     String @id @default(uuid())
  module String
  action String
  label  String

  roles RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  family     String
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([family])
}

/* ---------------- CATALOG / STOCK ---------------- */

enum ProductCategory {
  MONTURE
  VERRE
  LENTILLE
  ACCESSOIRE
  SERVICE
}

model Product {
  id         String          @id @default(uuid())
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sku        String
  category   ProductCategory
  brand      String?
  name       String
  attributes Json?
  buyPrice   Decimal         @db.Decimal(12, 2)
  sellPrice  Decimal         @db.Decimal(12, 2)
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  stockItems StockItem[]
  saleItems  SaleItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, category])
}

model StockItem {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  quantity  Int      @default(0)
  minAlert  Int      @default(0)
  updatedAt DateTime @updatedAt

  movements StockMovement[]

  @@unique([productId, branchId])
  @@index([tenantId, branchId])
  @@index([tenantId])
}

enum StockMovementType {
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT
  RETURN_IN
  TRANSFER
}

model StockMovement {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockItemId String
  stockItem   StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  type        StockMovementType
  quantity    Int // signé : +entrée, -sortie
  reason      String?
  saleId      String?
  createdById String?
  createdAt   DateTime          @default(now())

  @@index([tenantId, stockItemId])
  @@index([tenantId])
}

/* ---------------- CUSTOMERS / SALES ---------------- */

model Customer {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName     String
  lastName      String
  phone         String?
  email         String?
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())

  sales         Sale[]
  prescriptions OpticalPrescription[]
  lensOrders    LensOrder[]
  repairs       Repair[]

  @@index([tenantId])
}

model OpticalPrescription {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId        String
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  date              DateTime @default(now())
  prescriberName    String?
  odSphere          String?
  odCylinder        String?
  odAxis            String?
  odAddition        String?
  ogSphere          String?
  ogCylinder        String?
  ogAxis            String?
  ogAddition        String?
  pupillaryDistance String?
  lensType          String?
  notes             String?
  // Mesures avancées de montage
  odHeight          String? // hauteur de montage OD (mm)
  ogHeight          String? // hauteur de montage OG (mm)
  odNearPd          String? // écart pupillaire de près OD (mm)
  ogNearPd          String? // écart pupillaire de près OG (mm)
  vertex            String? // distance verre-œil (mm)
  pantoTilt         String? // angle pantoscopique (°)
  createdById       String?
  createdAt         DateTime @default(now())

  @@index([tenantId, customerId])
  @@index([tenantId])
}

enum SaleType {
  QUOTE
  SALE
  RETURN
}

enum LensOrderStatus {
  ORDERED
  RECEIVED
  MOUNTED
  DELIVERED
  CANCELLED
}

enum RepairStatus {
  RECEIVED
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

enum SaleStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model Sale {
  id              String     @id @default(uuid())
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId        String
  branch          Branch     @relation(fields: [branchId], references: [id])
  customerId      String?
  customer        Customer?  @relation(fields: [customerId], references: [id])
  cashierId       String
  cashier         User       @relation(fields: [cashierId], references: [id])
  number          String
  type            SaleType   @default(SALE)
  status          SaleStatus @default(DRAFT)
  subtotal        Decimal    @db.Decimal(12, 2)
  discountAmount  Decimal    @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal    @default(0) @db.Decimal(12, 2)
  insuranceAmount Decimal    @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal    @db.Decimal(12, 2)
  paidAmount      Decimal    @default(0) @db.Decimal(12, 2)
  currency        String     @default("XOF")
  // Retour/avoir : référence la vente d'origine remboursée.
  originalSaleId  String?
  originalSale    Sale?      @relation("SaleReturns", fields: [originalSaleId], references: [id])
  returns         Sale[]     @relation("SaleReturns")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  items    SaleItem[]
  payments Payment[]

  @@unique([tenantId, number])
  @@index([tenantId, branchId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  @@index([saleId])
}

/** Commande de verres/montures auprès d'un laboratoire ou fournisseur. */
model LensOrder {
  id           String          @id @default(uuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number       String
  customerId   String?
  customer     Customer?       @relation(fields: [customerId], references: [id])
  supplierName String?
  description  String // ex. « Verres progressifs 1.6 anti-reflet »
  status       LensOrderStatus @default(ORDERED)
  expectedAt   DateTime?
  cost         Decimal?        @db.Decimal(12, 2)
  notes        String?
  createdById  String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
}

/** Réparation / SAV d'une monture ou d'un équipement. */
model Repair {
  id          String       @id @default(uuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number      String
  customerId  String?
  customer    Customer?    @relation(fields: [customerId], references: [id])
  description String
  status      RepairStatus @default(RECEIVED)
  cost        Decimal?     @db.Decimal(12, 2)
  notes       String?
  createdById String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
}

/* ---------------- PAYMENTS (CinetPay-ready) ---------------- */

enum PaymentMethod {
  CASH
  WAVE
  ORANGE_MONEY
  MTN_MOMO
  MOOV_MONEY
  FREE_MONEY
  CARD
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED
  REFUNDED
}

model Payment {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleId      String
  sale        Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  method      PaymentMethod
  provider    String? // "cinetpay" | "manual" | "simulation"
  providerRef String?
  status      PaymentStatus @default(PENDING)
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("XOF")
  rawPayload  Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  transactions Transaction[]

  @@index([tenantId, saleId])
  @@index([provider, providerRef])
}

model Transaction {
  id        String        @id @default(uuid())
  paymentId String
  payment   Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  event     String
  status    PaymentStatus
  payload   Json?
  createdAt DateTime      @default(now())

  @@index([paymentId])
}

/* ---------------- CASH REGISTER ---------------- */

enum CashRegisterStatus {
  OPEN
  CLOSED
}

model CashRegister {
  id             String             @id @default(uuid())
  tenantId       String
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch             @relation(fields: [branchId], references: [id])
  openedById     String
  openedAt       DateTime           @default(now())
  closedById     String?
  closedAt       DateTime?
  openingAmount  Decimal            @db.Decimal(12, 2)
  closingAmount  Decimal?           @db.Decimal(12, 2)
  expectedAmount Decimal?           @db.Decimal(12, 2)
  status         CashRegisterStatus @default(OPEN)

  @@index([tenantId, branchId, status])
}

/* ---------------- AUDIT ---------------- */

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
}

/* ---------------- CLINIQUE (Phase 2) ---------------- */

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Eye {
  OD
  OG
  OU
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SurgeryStatus {
  PLANNED
  DONE
  CANCELLED
}

model Patient {
  id             String    @id @default(uuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  gender         Gender?
  dateOfBirth    DateTime?
  phone          String?
  email          String?
  address        String?
  bloodGroup     String?
  allergies      String?
  medicalHistory String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  consultations Consultation[]
  appointments  Appointment[]
  surgeries     Surgery[]

  @@index([tenantId])
}

model Consultation {
  id                String   @id @default(uuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId         String
  patient           Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practitionerName  String?
  date              DateTime @default(now())
  visualAcuityRight String?
  visualAcuityLeft  String?
  refractionRight   String?
  refractionLeft    String?
  tonometryRight    String?
  tonometryLeft     String?
  biomicroscopy     String?
  fundus            String?
  oct               String?
  visualField       String?
  diagnosis         String?
  prescription      String?
  notes             String?
  createdById       String?
  createdAt         DateTime @default(now())

  @@index([tenantId, patientId])
  @@index([tenantId])
}

model Appointment {
  id               String            @id @default(uuid())
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId        String
  patient          Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  practitionerName String?
  scheduledAt      DateTime
  reason           String?
  status           AppointmentStatus @default(SCHEDULED)
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([tenantId, scheduledAt])
  @@index([tenantId])
}

model Surgery {
  id            String        @id @default(uuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patientId     String
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  type          String
  eye           Eye           @default(OU)
  surgeonName   String?
  scheduledAt   DateTime?
  status        SurgeryStatus @default(PLANNED)
  outcome       String?
  followUpNotes String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tenantId, patientId])
  @@index([tenantId])
}

/* ---------------- GESTION (Phase 2) ---------------- */

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum ExpenseCategory {
  RENT
  SALARIES
  ELECTRICITY
  WATER
  INTERNET
  MARKETING
  TRANSPORT
  SUPPLIES
  MAINTENANCE
  TAXES
  OTHER
}

enum SupplierType {
  LOCAL
  INTERNATIONAL
}

enum InsurerType {
  HEALTH_INSURANCE
  MUTUAL
  PRIVATE
  THIRD_PARTY
}

model Employee {
  id        String         @id @default(uuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  phone     String?
  email     String?
  position  String
  salary    Decimal?       @db.Decimal(12, 2)
  hireDate  DateTime?
  status    EmployeeStatus @default(ACTIVE)
  branchId  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([tenantId])
}

model Expense {
  id          String          @id @default(uuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    ExpenseCategory
  label       String
  amount      Decimal         @db.Decimal(12, 2)
  date        DateTime        @default(now())
  branchId    String?
  notes       String?
  createdById String?
  createdAt   DateTime        @default(now())

  @@index([tenantId, date])
  @@index([tenantId])
}

model Supplier {
  id          String       @id @default(uuid())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  type        SupplierType @default(LOCAL)
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId])
}

model Insurer {
  id              String      @id @default(uuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name            String
  type            InsurerType @default(HEALTH_INSURANCE)
  coveragePercent Int         @default(0)
  phone           String?
  email           String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tenantId])
}

/* ---------------- ABONNEMENTS SaaS ---------------- */

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum SubInvoiceStatus {
  PENDING
  PAID
  FAILED
  VOID
}

model SubscriptionPlan {
  id           String   @id @default(uuid())
  code         String   @unique // TRIAL | STANDARD | PREMIUM
  name         String
  description  String?
  priceMonthly Decimal  @db.Decimal(12, 2)
  currency     String   @default("XOF")
  trialDays    Int      @default(0)
  maxUsers     Int? // null = illimité
  maxBranches  Int?
  maxPatients  Int?
  maxSales     Int?
  features     Json?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(uuid())
  tenantId           String             @unique
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId             String
  plan               SubscriptionPlan   @relation(fields: [planId], references: [id])
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  autoRenew          Boolean            @default(true)
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  invoices SubscriptionInvoice[]

  @@index([status])
}

model SubscriptionInvoice {
  id             String                @id @default(uuid())
  tenantId       String
  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription          @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  planId         String
  number         String
  amount         Decimal               @db.Decimal(12, 2)
  currency       String                @default("XOF")
  status         SubInvoiceStatus      @default(PENDING)
  periodStart    DateTime
  periodEnd      DateTime
  dueDate        DateTime
  paidAt         DateTime?
  createdAt      DateTime              @default(now())

  payments SubscriptionPayment[]

  @@unique([tenantId, number])
  @@index([tenantId])
}

model SubscriptionPayment {
  id          String              @id @default(uuid())
  tenantId    String
  invoiceId   String
  invoice     SubscriptionInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  method      PaymentMethod
  provider    String?
  providerRef String?
  status      PaymentStatus       @default(PENDING)
  amount      Decimal             @db.Decimal(12, 2)
  currency    String              @default("XOF")
  rawPayload  Json?
  // Contexte Meta Conversions API capturé à l'initiation (ip/UA/fbp/fbc),
  // réutilisé à la confirmation (souvent asynchrone, via webhook) pour un
  // évènement Purchase correctement attribué.
  capiContext Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([tenantId])
  @@index([provider, providerRef])
}

model SupportTicket {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("OPEN") // OPEN | CLOSED
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([tenantId])
}

/// Équipe de l'éditeur ayant accès à la console fondateur (cross-tenant).
/// S'ajoute aux emails de PLATFORM_ADMIN_EMAILS (bootstrap via env), sans les
/// remplacer : retirer une ligne ici ne révoque pas un email listé dans l'env.
model PlatformOperator {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  addedById String?
  createdAt DateTime @default(now())
}

/* ---------------- CHATBOT WHATSAPP ---------------- */

/// Prospect ayant écrit au chatbot commercial WhatsApp. Cross-tenant : ce sont
/// des leads du fondateur, non rattachés à un établissement. Alimenté par le
/// webhook WhatsApp Cloud API (module whatsapp) via le client Prisma système.
model WhatsappContact {
  id            String            @id @default(uuid())
  /// Numéro au format wa_id (ex. "2250596609036", sans « + »).
  phone         String            @unique
  /// Nom du profil WhatsApp du prospect (fourni par Meta).
  profileName   String?
  /// true = le fondateur a repris la main → le bot n'auto-répond plus à ce contact.
  botPaused     Boolean           @default(false)
  lastMessageAt DateTime          @default(now())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  messages      WhatsappMessage[]

  @@index([lastMessageAt])
}

/// Un message de la conversation (entrant ou réponse du bot). Sert de mémoire
/// pour poser les questions de qualification une par une, dans l'ordre.
model WhatsappMessage {
  id          String          @id @default(uuid())
  contactId   String
  contact     WhatsappContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  /// 'user' (prospect) | 'assistant' (bot).
  role        String
  text        String
  /// Identifiant Meta du message entrant (déduplication des redistributions).
  waMessageId String?
  createdAt   DateTime        @default(now())

  @@index([contactId, createdAt])
  @@index([waMessageId])
}
