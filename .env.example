# ============================================================
# OculoSaaS — Variables d'environnement (modèle)
# Copier vers apps/api/.env et remplir les valeurs.
# NE JAMAIS committer le vrai .env (il est dans .gitignore).
# ============================================================

# --- Base de données ---
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/oculo_dev?schema=public"

# --- Serveur API ---
API_PORT=4000
NODE_ENV=development

# --- CORS / Cookies (frontend Vite) ---
CORS_ORIGIN="http://localhost:5173"
COOKIE_DOMAIN="localhost"
COOKIE_SECURE=false

# --- JWT ---
# En production : utiliser des secrets longs et aléatoires (32+ octets).
JWT_ACCESS_SECRET="dev-access-secret-change-me-in-production-0123456789"
JWT_ACCESS_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# --- Chiffrement au repos (config CinetPay, etc.) ---
# Doit faire exactement 64 caractères hexadécimaux (32 octets) pour AES-256-GCM.
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# --- Mailer ---
# MAIL_DRIVER=console : les emails (reset password) sont logués dans la console (dev).
# MAIL_DRIVER=smtp : utilise les variables SMTP_* ci-dessous (prod).
MAIL_DRIVER=console
MAIL_FROM="OculoSaaS <no-reply@oculosaas.africa>"
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""

# --- Sécurité auth ---
MAX_FAILED_LOGINS=5
ACCOUNT_LOCK_MINUTES=15

# --- CinetPay (laisser vide tant qu'aucun compte réel) ---
# Tant que ces valeurs sont absentes, le mode simulation est utilisé.
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""
CINETPAY_BASE_URL="https://api-checkout.cinetpay.com/v2"
CINETPAY_WEBHOOK_SECRET=""

# --- Frontend (apps/web/.env) ---
# VITE_API_URL="http://localhost:4000"
